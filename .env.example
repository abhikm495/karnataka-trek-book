EMAIL=your-email@example.com
PASSWORD=your-password
TEST_MODE=dry-run

# Booking IDs (from DevTools when slots open)
TREK_ID=143
DATE=2026-06-22
TIME_SLOT_ID=46
TIME_SLOT_MAPPING_ID=237
UPI_VPA=1234567890@yescred

# JSON array — max 3 visitors (first member mobile receives OTP)
MEMBERS='[{"name":"Visitor One","age":25,"gender":"Male","idType":"Pancard","idNumber":"ABCDE1234F","mobile":"9876543210"}]'

# -----------------------------------------------------------------------------
# OTP automation
# -----------------------------------------------------------------------------
# OTP_MODE=manual   — type OTP in terminal when prompted (default)
# OTP_MODE=adb      — read OTP from Android SMS over USB (see Android steps below)
# OTP_MODE=webhook  — receive OTP via HTTP from phone (see Android/iPhone steps below)
#
OTP_MODE=adb
# OTP_WEBHOOK_PORT=3847
# OTP_TIMEOUT_MS=120000

# -----------------------------------------------------------------------------
# ANDROID — Option A: adb (recommended for USB-connected Android, e.g. Poco/Xiaomi)
# -----------------------------------------------------------------------------
# Mac setup:
#   1. brew install android-platform-tools
#   2. Verify: which adb  →  /opt/homebrew/bin/adb
#   3. Set OTP_MODE=adb in this file
#
# Windows setup:
#   1. Download Platform Tools: https://developer.android.com/tools/releases/platform-tools
#   2. Extract the zip (e.g. C:\platform-tools)
#   3. Add that folder to PATH:
#        Settings → System → About → Advanced system settings → Environment Variables
#        Edit "Path" → New → C:\platform-tools
#   4. Open a new Command Prompt or PowerShell
#   5. Verify: where adb
#      Expected: C:\platform-tools\adb.exe
#   6. Set OTP_MODE=adb in this file
#
# Phone setup (Poco / Xiaomi / HyperOS):
#   1. Settings → About phone → tap MIUI/HyperOS version 7 times
#   2. Settings → Additional settings → Developer options
#   3. Enable: USB debugging
#   4. Enable: USB debugging (Security settings)   ← required on Xiaomi/POCO
#   5. Connect phone to PC with a data USB cable
#   6. On phone popup: tap "Allow USB debugging" → check "Always allow"
#   7. On PC verify: adb devices
#      Expected: XXXXXXXX    device
#   (Windows: if "unauthorized", install phone USB driver from manufacturer or use File Transfer mode)
#
# Test SMS read (optional):
#   adb shell "content query --uri content://sms/inbox --projection body,date"
#   You should see KFDTRK OTP lines like: "... is 985231. From KFDTRK"
#
# Run booking:
#   npm run book:api

# -----------------------------------------------------------------------------
# ANDROID — Option B: webhook (if adb SMS read is blocked on your phone)
# -----------------------------------------------------------------------------
# Mac setup:
#   1. Set OTP_MODE=webhook
#   2. Find Mac IP: ipconfig getifaddr en0
#   3. Bot listens on: http://127.0.0.1:3847/otp  (or OTP_WEBHOOK_PORT)
#
# Phone setup (MacroDroid / SMS Forwarder / Tasker):
#   1. Install SMS automation app (e.g. MacroDroid)
#   2. Trigger: incoming SMS contains "KFDTRK" or "Forest Ecotourism"
#   3. Action: HTTP POST to http://<MAC_IP>:3847/otp
#   4. Body: full SMS text, or JSON: {"message":"{{sms_body}}"}
#
# Test from Mac (while bot is waiting for OTP):
#   curl -X POST http://127.0.0.1:3847/otp -d '{"message":"Your OTP is 123456. From KFDTRK"}'

# -----------------------------------------------------------------------------
# iPHONE — webhook via Shortcuts (no direct SMS access on iOS)
# -----------------------------------------------------------------------------
# Mac setup:
#   1. Set OTP_MODE=webhook
#   2. Find Mac IP: ipconfig getifaddr en0
#   3. Mac and iPhone must be on the same Wi‑Fi
#
# iPhone setup (Shortcuts app):
#   1. Open Shortcuts → Automation → + → Personal Automation
#   2. Trigger: "Message" → Sender: Any / or filter by sender
#      Condition: Message contains "KFDTRK" or "Forest Ecotourism"
#   3. Add action: "Get Text from Input" (message body)
#   4. Add action: "Get Contents of URL"
#        URL: http://<MAC_IP>:3847/otp
#        Method: POST
#        Request Body: JSON → {"message": "<Shortcut Input>"}
#   5. Turn OFF "Ask Before Running" for instant automation
#
# Test from Mac (while bot is waiting for OTP):
#   curl -X POST http://127.0.0.1:3847/otp -d '{"message":"Your OTP is 123456. From KFDTRK"}'

